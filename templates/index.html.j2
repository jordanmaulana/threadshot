{% extends "_layout.html.j2" %}

{% block title %}Threadshot — Threads posts as PNG{% endblock %}

{% block scripts %}
  <script src="https://unpkg.com/htmx.org@2.0.3"></script>
{% endblock %}

{% block body %}
<section class="max-w-[640px] mx-auto px-5 pt-10 md:pt-16">

  <h1 class="text-ink text-[28px] md:text-[34px] leading-[1.1] font-semibold tracking-tight">
    Threads <span class="text-mute">&rarr;</span> PNG
  </h1>
  <p class="mt-2 text-[15px] text-mute leading-relaxed">
    Paste a Threads link. Get a clean PNG.
  </p>

  {% if adsense_client %}
  <div class="mt-6">
    <ins class="adsbygoogle block" style="display:block" data-ad-client="{{ adsense_client }}"
         data-ad-slot="0000000000" data-ad-format="auto" data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>
  {% endif %}

  <form hx-post="/shot" hx-target="#result" hx-swap="innerHTML" hx-disabled-elt="find button"
        class="mt-7 group/form">
    <div class="bg-surface border border-border rounded-2xl px-4 py-3.5 focus-within:border-border-strong transition-colors">
      <label for="url" class="sr-only">Threads post URL</label>
      <input id="url" type="url" name="url" required
             placeholder="https://www.threads.com/@user/post/..."
             class="t-input">
      <div class="mt-3 flex items-center justify-between">
        <span class="text-[12px] text-mute-2">Public posts only.</span>
        <button type="submit" class="t-pill t-pill-primary group">
          <svg class="hidden group-disabled:inline animate-spin h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"/>
          </svg>
          <span class="group-disabled:hidden">Get PNG</span>
          <span class="hidden group-disabled:inline">Working&hellip;</span>
        </button>
      </div>
    </div>
    {% if message %}<p class="mt-3 text-danger text-[13px]">{{ message }}</p>{% endif %}
  </form>

  <ul class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-2 text-[12.5px] text-mute-2">
    <li class="inline-flex items-center gap-1.5">
      <span class="w-1.5 h-1.5 rounded-full bg-mute-2"></span> Paste link
    </li>
    <li class="inline-flex items-center gap-1.5">
      <span class="w-1.5 h-1.5 rounded-full bg-mute-2"></span> We render in a real browser
    </li>
    <li class="inline-flex items-center gap-1.5">
      <span class="w-1.5 h-1.5 rounded-full bg-mute-2"></span> Download crisp PNG
    </li>
  </ul>

  <section id="result" class="mt-8"></section>

  {% if adsense_client %}
  <div class="mt-14">
    <ins class="adsbygoogle block" style="display:block" data-ad-client="{{ adsense_client }}"
         data-ad-slot="1111111111" data-ad-format="auto" data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>
  {% endif %}

</section>
{% endblock %}

{% block end_scripts %}
{% if ga_measurement_id %}
<script>
  document.body.addEventListener('htmx:afterOnLoad', function(evt) {
    if (evt.detail.elt.matches('form') && evt.detail.xhr.status === 200) {
      gtag('event', 'screenshot', { 'event_category': 'engagement' });
    }
  });
</script>
{% endif %}
{% endblock %}
