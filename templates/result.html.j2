<figure class="m-0">
  <img src="data:image/png;base64,{{ img_b64 }}" alt="Screenshot of {{ post.author }}'s post"
       class="max-w-full rounded-xl shadow-sm">
  <figcaption class="mt-3 flex flex-wrap gap-2.5">
    <a href="data:image/png;base64,{{ img_b64 }}" download="{{ post.handle }}-{{ post.url.split('/')[-1] }}.png"
       class="inline-block px-3.5 py-2 bg-neutral-900 text-white text-sm rounded-lg hover:bg-neutral-800 no-underline">Download PNG</a>
    <a href="{{ post.url }}" target="_blank" rel="noopener noreferrer"
       class="inline-block px-3.5 py-2 bg-neutral-900 text-white text-sm rounded-lg hover:bg-neutral-800 no-underline">Open on Threads</a>
  </figcaption>
</figure>
