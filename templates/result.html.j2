<figure class="m-0 animate-[fadeUp_0.5s_cubic-bezier(0.16,1,0.3,1)]">
  <style>
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>

  <p class="eyebrow mb-4 flex items-center gap-3">
    <span class="inline-block w-2 h-2 rounded-full bg-accent"></span>
    Ready
  </p>

  <div class="relative inline-block max-w-full">
    <img src="data:image/png;base64,{{ img_b64 }}"
         alt="Screenshot of {{ post.author }}'s post"
         class="block max-w-full rounded-2xl shadow-[0_24px_70px_-24px_rgba(13,13,12,0.35),0_2px_6px_-2px_rgba(13,13,12,0.08)]">
  </div>

  <figcaption class="mt-5">
    <p class="font-display italic text-mute text-[14px] mb-4">{{ post.handle }}-{{ post.url.split('/')[-1] }}.png</p>
    <div class="flex flex-wrap gap-3 items-center">
      <a href="data:image/png;base64,{{ img_b64 }}"
         download="{{ post.handle }}-{{ post.url.split('/')[-1] }}.png"
         class="inline-flex items-center gap-2 px-5 py-2.5 bg-ink text-paper text-[14px] font-semibold rounded-full hover:bg-accent transition-colors no-underline">
        Download PNG
        <span aria-hidden="true">&darr;</span>
      </a>
      <a href="{{ post.url }}" target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-2 px-5 py-2.5 bg-paper text-ink text-[14px] font-semibold rounded-full border border-hairline hover:border-ink transition-colors no-underline">
        Open on Threads
        <span aria-hidden="true">&#8599;</span>
      </a>
      <a href="/" class="ml-2 text-[13px] text-mute hover:text-accent transition-colors no-underline">
        Shoot another &rarr;
      </a>
    </div>
  </figcaption>
</figure>
