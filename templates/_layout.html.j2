<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#0a0a0a">
  <title>{% block title %}Threadshot{% endblock %}</title>
  <meta name="description" content="{% block description %}Paste a Threads URL. Get a clean PNG you can share anywhere.{% endblock %}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/static/tailwind.css">
  {% block scripts %}{% endblock %}
  {% if adsense_client %}
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client={{ adsense_client }}"
          crossorigin="anonymous"></script>
  {% endif %}
  {% if ga_measurement_id %}
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ ga_measurement_id }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '{{ ga_measurement_id }}');
  </script>
  {% endif %}
  {% block extra_head %}{% endblock %}
</head>
<body class="bg-bg text-ink font-sans min-h-screen flex flex-col selection:bg-ink/20 selection:text-ink">

  <header class="sticky top-0 z-20 w-full bg-bg/85 backdrop-blur border-b border-border">
    <div class="max-w-[640px] mx-auto px-5 h-14 flex items-center justify-between">
      <a href="/" class="inline-flex items-center gap-2 no-underline">
        <span aria-hidden="true" class="block w-2.5 h-2.5 rounded-[3px] bg-accent"></span>
        <span class="text-[15px] font-semibold tracking-tight text-ink">threadshot</span>
      </a>
      <nav class="flex items-center gap-5 text-[13px] text-mute">
        <a href="/about" class="hover:text-ink transition-colors no-underline">About</a>
        <a href="/privacy" class="hover:text-ink transition-colors no-underline">Privacy</a>
      </nav>
    </div>
  </header>

  <main class="flex-1 w-full">
    {% block body %}{% endblock %}
  </main>

  <footer class="w-full mt-20">
    <div class="max-w-[640px] mx-auto px-5 pb-8 pt-6 border-t border-border">
      <div class="flex flex-wrap items-center justify-between gap-3 text-[12px] text-mute-2">
        <span>© {{ year or 2026 }} Threadshot</span>
        <span class="flex items-center gap-4">
          <a href="/about" class="hover:text-ink transition-colors no-underline">About</a>
          <a href="/privacy" class="hover:text-ink transition-colors no-underline">Privacy</a>
        </span>
      </div>
    </div>
  </footer>

  {% block end_scripts %}{% endblock %}
</body>
</html>
