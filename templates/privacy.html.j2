{% extends "_layout.html.j2" %}
{% block title %}Privacy — Threadshot{% endblock %}

{% block body %}
<section class="max-w-3xl mx-auto px-6 md:px-10 pt-16 md:pt-24">
  <p class="eyebrow mb-4">Privacy</p>
  <h1 class="font-display text-ink leading-[1] tracking-tight text-[clamp(2.25rem,5vw,3.75rem)]">
    What we <em class="italic text-accent">keep.</em>
  </h1>

  <div class="mt-10 space-y-5 text-[17px] leading-relaxed text-ink/85 max-w-[62ch]">
    <p>
      Threadshot does not store post URLs, generated images, or personal data. Posts are fetched from threads.com on demand and rendered in memory.
    </p>
    <p class="text-mute">
      Analytics and ads, where enabled, are provided by Google. See Google's policy for details on what they collect.
    </p>
  </div>

  <hr class="hairline-rule my-10">

  <a href="/" class="inline-flex items-center gap-2 text-[14px] text-ink hover:text-accent transition-colors no-underline">
    <span aria-hidden="true">&larr;</span> Back to the shooter
  </a>
</section>
{% endblock %}
