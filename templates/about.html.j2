{% extends "_layout.html.j2" %}
{% block title %}About — Threadshot{% endblock %}

{% block body %}
<section class="max-w-[640px] mx-auto px-5 pt-12 md:pt-16">
  <h1 class="text-ink text-[28px] md:text-[32px] font-semibold tracking-tight leading-[1.1]">
    About
  </h1>

  <div class="mt-6 space-y-4 text-[15px] leading-relaxed text-ink/85">
    <p>
      Threadshot turns any public Threads post into a clean PNG you can share. Paste the post URL on the home page and download the screenshot.
    </p>
    <p class="text-mute">
      Under the hood we render the post in a real headless Chromium with avatars and media inlined, so the image is self-contained — no broken links a week later, no Threads chrome around the edges, just the post.
    </p>
  </div>

  <a href="/" class="mt-8 inline-flex items-center gap-1.5 text-[14px] text-mute hover:text-ink transition-colors no-underline">
    <span aria-hidden="true">&larr;</span> Back
  </a>
</section>
{% endblock %}
