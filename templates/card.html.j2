<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<style>{{ tailwind_css|safe }}</style>
<style>
  body { background: transparent; }
  #card {
    background:
      radial-gradient(120% 80% at 0% 0%, rgba(255, 255, 255, 0.045) 0%, rgba(255, 255, 255, 0) 55%),
      radial-gradient(80% 60% at 100% 100%, rgba(184, 65, 11, 0.06) 0%, rgba(184, 65, 11, 0) 60%),
      #0a0a0a;
  }
  #card .ts-num { font-variant-numeric: tabular-nums; }
  #card .ts-watermark { font-feature-settings: "ss01"; }
</style>
</head>
<body class="p-6 antialiased [font-family:-apple-system,BlinkMacSystemFont,'Segoe_UI','Helvetica_Neue',system-ui,sans-serif]">
<div id="card" class="w-[552px] text-[#ededed] border border-white/[0.07] rounded-[20px] pt-[16px] pb-[14px] px-[20px] relative overflow-hidden">

  <div class="flex items-center gap-2.5">
    {% if post.avatar_url %}
      <div class="relative shrink-0">
        <img class="w-[38px] h-[38px] rounded-full object-cover bg-[#242424]" src="{{ post.avatar_url }}" alt="">
        <span class="absolute inset-0 rounded-full ring-1 ring-inset ring-white/10 pointer-events-none"></span>
      </div>
    {% else %}
      <div class="w-[38px] h-[38px] rounded-full bg-[#242424] shrink-0 ring-1 ring-inset ring-white/10"></div>
    {% endif %}
    <span class="font-bold text-[15px] text-white tracking-[-0.01em]">{{ post.handle }}</span>
    {% if post.time_text %}<span class="text-[#7a7a7a] text-[13px] ml-1">{{ post.time_text }}</span>{% endif %}
    <span class="ml-auto text-[#5a5a5a] text-xl leading-none tracking-[2px] pb-1.5">···</span>
  </div>

  {% if post.text %}
    <div class="ml-[48px] mt-2 text-[15.5px] leading-[1.5] whitespace-pre-wrap break-words text-[#ededed]">{{ post.text }}</div>
  {% endif %}

  {% if post.media %}
    <div class="ml-[48px] mt-3.5 grid gap-1 {% if post.media|length >= 2 %}grid-cols-2{% else %}grid-cols-1{% endif %} rounded-[14px] overflow-hidden border border-white/[0.06]">
      {% for m in post.media[:4] %}
        <img class="w-full block max-h-[520px] object-cover bg-[#141414]" src="{{ m }}" alt="">
      {% endfor %}
    </div>
  {% endif %}

  <div class="ml-[48px] mt-3.5 flex gap-[22px] text-[#9a9a9a] text-[13px] ts-num">
    <span class="inline-flex items-center gap-1.5 h-7 px-0.5">
      <svg class="w-[19px] h-[19px]" viewBox="0 0 24 24" fill="none" stroke="#bdbdbd" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7-4.5-9.5-9C.7 8.6 2.7 5 6 5c1.9 0 3.4 1 4 2.3C10.6 6 12.1 5 14 5c3.3 0 5.3 3.6 3.5 7-2.5 4.5-9.5 9-9.5 9z"/></svg>
      {% if post.like_count is not none %}{{ post.like_count }}{% endif %}
    </span>
    <span class="inline-flex items-center gap-1.5 h-7 px-0.5">
      <svg class="w-[19px] h-[19px]" viewBox="0 0 24 24" fill="none" stroke="#bdbdbd" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12c0 4.4-4 8-9 8-1.4 0-2.7-.3-3.9-.8L3 21l1.8-4.5C3.7 15 3 13.6 3 12c0-4.4 4-8 9-8s9 3.6 9 8z"/></svg>
      {% if post.reply_count is not none %}{{ post.reply_count }}{% endif %}
    </span>
    <span class="inline-flex items-center gap-1.5 h-7 px-0.5">
      <svg class="w-[19px] h-[19px]" viewBox="0 0 24 24" fill="none" stroke="#bdbdbd" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M17 2l4 4-4 4"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><path d="M7 22l-4-4 4-4"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
      {% if post.repost_count is not none %}{{ post.repost_count }}{% endif %}
    </span>
    <span class="inline-flex items-center gap-1.5 h-7 px-0.5">
      <svg class="w-[19px] h-[19px]" viewBox="0 0 24 24" fill="none" stroke="#bdbdbd" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4 20-7z"/></svg>
    </span>
  </div>

  <div class="ml-[48px] mt-4 pt-3 border-t border-white/[0.05] flex items-center justify-between">
    <span class="text-[10px] uppercase tracking-[0.22em] text-[#4a4a4a] ts-watermark">shot with</span>
    <span class="inline-flex items-center gap-1.5 text-[10px] uppercase tracking-[0.22em] text-[#6a6a6a]">
      <span aria-hidden="true" class="inline-block w-[7px] h-[7px] rounded-[2px] bg-[#b8410b]"></span>
      threadshot
    </span>
  </div>

</div>
</body>
</html>
